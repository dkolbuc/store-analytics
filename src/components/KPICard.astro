---
import { deltaClass, fmtDelta, deltaArrow } from "../lib/delta.ts";

interface Props {
  label: string;
  current: string;
  compare: string;
  change: number | null;
  /** Klucz metryki do ustalenia semantyki koloru (revenue, cost, roas, …) */
  metricKey: string;
}

const { label, current, compare, change, metricKey } = Astro.props;
const cls = deltaClass(metricKey, change);
const arrow = deltaArrow(change);
const delta = fmtDelta(change);
---

<div class="kpi-card">
  <div class="kpi-card__label">{label}</div>
  <div class="kpi-card__value">{current}</div>
  <div class="kpi-card__compare">
    <span class="kpi-card__compare-val">vs {compare}</span>
    {change !== null && (
      <span class={`delta ${cls}`}>{arrow} {delta}</span>
    )}
  </div>
</div>
