---
interface Props { summary: string | null; }
const { summary } = Astro.props;
---

<div class="ai-summary">
  <div class="ai-summary__header">
    <span class="ai-summary__icon">✦</span>
    <h2 style="margin:0">Podsumowanie AI</h2>
  </div>
  {summary
    ? <p class="ai-summary__content">{summary}</p>
    : <p class="ai-summary__empty">Brak danych lub klucz GEMINI_API_KEY nie skonfigurowany.</p>
  }
</div>
