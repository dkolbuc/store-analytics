---
interface Props {
  summary: string | null;
  status: "ok" | "no-key" | "no-data" | "error";
}
const { summary, status } = Astro.props;

const EMPTY_MESSAGES: Record<string, string> = {
  "no-key":  "Klucz GEMINI_API_KEY nie skonfigurowany.",
  "no-data": "Brak danych w wybranym okresie.",
  "error":   "Podsumowanie chwilowo niedostępne.",
};
---

<div class="ai-summary">
  <div class="ai-summary__header">
    <span class="ai-summary__icon">✦</span>
    <h2 style="margin:0">Podsumowanie AI</h2>
  </div>
  {summary
    ? <p class="ai-summary__content">{summary}</p>
    : <p class="ai-summary__empty">{EMPTY_MESSAGES[status] ?? ""}</p>
  }
</div>
