---
// Import CSS przez Astro — bundler wstrzykuje <link> do <head> automatycznie.
// Nie używaj ścieżki /styles/global.css jako publicznego URL-a (plik jest w src/, nie public/).
import "../styles/global.css";

interface Props { title: string; }
const { title } = Astro.props;
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <div id="nav-progress" aria-hidden="true"></div>
    <slot />
    <script is:inline>
      (function () {
        var bar = document.getElementById('nav-progress');
        if (!bar) return;
        window.addEventListener('beforeunload', function () {
          bar.classList.add('nav-progress--active');
        });
        // Bfcache restore — usuń wskaźnik gdy przeglądarka odtworzy stronę z cache
        window.addEventListener('pageshow', function (e) {
          if (e.persisted) bar.classList.remove('nav-progress--active');
        });
      }());
    </script>
  </body>
</html>
