---
import "../styles/global.css";

const error = Astro.url.searchParams.get("error") === "1";
---
<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Logowanie — Store Analytics</title>
  </head>
  <body>
    <div class="login-wrap">
      <div class="login-card">
        <div class="login-brand">Store Analytics</div>
        {error && (
          <div class="login-error">Nieprawidłowe hasło. Spróbuj ponownie.</div>
        )}
        <form method="POST" action="/api/auth/login" class="login-form">
          <label for="password" class="login-label">Hasło</label>
          <input
            id="password"
            name="password"
            type="password"
            class="login-input"
            autocomplete="current-password"
            autofocus
            required
          />
          <button type="submit" class="login-btn">Zaloguj się</button>
        </form>
      </div>
    </div>

    <style>
      .login-wrap {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--bg);
        padding: 1rem;
      }
      .login-card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: var(--shadow);
        padding: 2rem 2.5rem;
        width: 100%;
        max-width: 360px;
      }
      .login-brand {
        font-size: 1.15rem;
        font-weight: 700;
        color: var(--accent);
        letter-spacing: -.01em;
        margin-bottom: 1.5rem;
        text-align: center;
      }
      .login-error {
        background: var(--negative-bg);
        color: var(--negative);
        border: 1px solid var(--negative);
        border-radius: var(--radius-s);
        padding: .5rem .75rem;
        font-size: .82rem;
        margin-bottom: 1rem;
      }
      .login-form {
        display: flex;
        flex-direction: column;
        gap: .6rem;
      }
      .login-label {
        font-size: .72rem;
        font-weight: 600;
        color: var(--muted);
        text-transform: uppercase;
        letter-spacing: .05em;
      }
      .login-input {
        appearance: none;
        -webkit-appearance: none;
        width: 100%;
        padding: .45rem .65rem;
        font-family: inherit;
        font-size: .9rem;
        border: 1px solid var(--border-2);
        border-radius: var(--radius-s);
        color: var(--text);
        background: var(--surface);
        outline: none;
        transition: border-color .15s, box-shadow .15s;
      }
      .login-input:focus {
        border-color: var(--accent);
        box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 15%, transparent);
      }
      .login-btn {
        margin-top: .4rem;
        padding: .5rem;
        font-family: inherit;
        font-size: .9rem;
        font-weight: 600;
        color: #fff;
        background: var(--accent);
        border: none;
        border-radius: var(--radius-s);
        cursor: pointer;
        transition: opacity .15s;
      }
      .login-btn:hover { opacity: .88; }
    </style>
  </body>
</html>
