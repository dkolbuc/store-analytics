---
import Layout from "../components/Layout.astro";
import KPICard from "../components/KPICard.astro";
import AISummary from "../components/AISummary.astro";
import ShopSelector from "../islands/ShopSelector";
import PeriodPicker from "../islands/PeriodPicker";
import SalesChart from "../islands/SalesChart";
import AdsChart from "../islands/AdsChart";
import Ga4Chart from "../islands/Ga4Chart";

import { getDB, dbAll } from "../lib/db.ts";
import {
  parsePeriodParams, resolvePeriods, todayWarsaw, formatPeriodLabel, percentChange,
  type PeriodParams,
} from "../lib/dates.ts";
import { formatPLN, formatPLNShort, groszeToPLN } from "../lib/money.ts";
import { calcROAS, formatROAS, calcCPC, calcCTR } from "../lib/roas.ts";
import { getOrGenerateSummary, type SummaryInput } from "../lib/gemini.ts";
import { deltaClass, fmtDelta, deltaArrow } from "../lib/delta.ts";
import {
  querySales, queryAds, queryGA4, queryTopProducts,
  querySalesDaily, queryAdsDaily, queryGA4Daily,
  queryAdsConversions, queryGA4Events,
  ZERO_SALES, ZERO_ADS, ZERO_GA4,
  type SalesMetrics, type AdsMetrics, type GA4Metrics,
  type DailyPoint, type DailyAdsPoint, type TopProduct,
  type AdsConversionRow, type GA4EventRow,
} from "../lib/queries.ts";

// ---------------------------------------------------------------------------
// 1. Parametry URL i rozwiązanie okresów
// ---------------------------------------------------------------------------

const db = getDB(Astro.locals);
const today = todayWarsaw();

// Parsowanie i rozwiązywanie okresu opakowane w try/catch — błąd parametrów nie wywołuje 500
const { params, mainRange, compareRange, periodError } = (() => {
  try {
    const p = parsePeriodParams(Astro.url.searchParams);
    const { main, compare } = resolvePeriods(p, today);
    return { params: p, mainRange: main, compareRange: compare, periodError: null as string | null };
  } catch (err) {
    console.error("[Okres] Błąd parsowania parametrów:", err);
    const p: PeriodParams = { type: "month", anchor: "current", compare: "previous" };
    const { main, compare } = resolvePeriods(p, today);
    return { params: p, mainRange: main, compareRange: compare,
             periodError: "Nieprawidłowe parametry okresu — wyświetlam bieżący miesiąc." };
  }
})();

// Czy bieżący okres jest w toku (period-to-date)?
const isInProgress = params.type !== "custom" && mainRange.end === today;

// Etykiety kontekstowe
const mainLabel    = formatPeriodLabel(mainRange, params.type);
const compareLabel = formatPeriodLabel(compareRange, params.type);

// ---------------------------------------------------------------------------
// 2. Lista sklepów i wybrany sklep
// ---------------------------------------------------------------------------

interface ShopRow { shop_id: string; name: string; data_version: number; }

let shops: ShopRow[] = [];
try {
  shops = await dbAll<ShopRow>(
    db,
    "SELECT shop_id, name, data_version FROM shops WHERE active = 1 ORDER BY name"
  );
} catch { /* pusta lista przy braku tabeli */ }

const selectedShopId = Astro.url.searchParams.get("shop") ?? shops[0]?.shop_id ?? "";
const selectedShop   = shops.find((s) => s.shop_id === selectedShopId);

// ---------------------------------------------------------------------------
// 3. Agregacje D1 (graceful degradation)
// ---------------------------------------------------------------------------

let mainSales: SalesMetrics   = ZERO_SALES;
let cmpSales:  SalesMetrics   = ZERO_SALES;
let mainAds:   AdsMetrics     = ZERO_ADS;
let cmpAds:    AdsMetrics     = ZERO_ADS;
let mainGA4:   GA4Metrics     = ZERO_GA4;
let cmpGA4:    GA4Metrics     = ZERO_GA4;
let topProducts: TopProduct[] = [];
let mainSalesDaily:  DailyPoint[]    = [];
let cmpSalesDaily:   DailyPoint[]    = [];
let mainAdsDaily:    DailyAdsPoint[] = [];
let cmpAdsDaily:     DailyAdsPoint[] = [];
let mainGA4Daily:    DailyPoint[]    = [];
let cmpGA4Daily:     DailyPoint[]    = [];
let adsConversions:  AdsConversionRow[] = [];
let ga4Events:       GA4EventRow[]      = [];

if (selectedShopId) {
  try {
    [
      mainSales, cmpSales, mainAds, cmpAds, mainGA4, cmpGA4, topProducts,
      mainSalesDaily, cmpSalesDaily, mainAdsDaily, cmpAdsDaily, mainGA4Daily, cmpGA4Daily,
    ] = await Promise.all([
      querySales(db, selectedShopId, mainRange),
      querySales(db, selectedShopId, compareRange),
      queryAds(db, selectedShopId, mainRange),
      queryAds(db, selectedShopId, compareRange),
      queryGA4(db, selectedShopId, mainRange),
      queryGA4(db, selectedShopId, compareRange),
      queryTopProducts(db, selectedShopId, mainRange),
      querySalesDaily(db, selectedShopId, mainRange),
      querySalesDaily(db, selectedShopId, compareRange),
      queryAdsDaily(db, selectedShopId, mainRange),
      queryAdsDaily(db, selectedShopId, compareRange),
      queryGA4Daily(db, selectedShopId, mainRange),
      queryGA4Daily(db, selectedShopId, compareRange),
    ]);
  } catch (e) {
    console.error("Błąd zapytań D1:", e);
  }

  try {
    adsConversions = await queryAdsConversions(db, selectedShopId, mainRange);
  } catch (e) {
    console.error("Błąd zapytania konwersji Ads:", e);
  }
  try {
    ga4Events = await queryGA4Events(db, selectedShopId, mainRange);
    if (ga4Events.length > 0) {
      const names = [...new Set(ga4Events.map((r) => r.eventName))].join(", ");
      console.log(`[GA4 events] ${ga4Events.length} wierszy, zdarzenia: ${names}`);
    } else {
      console.warn("[GA4 events] zapytanie OK, ale 0 wierszy — sprawdź shop_id i zakres dat");
    }
  } catch (e) {
    console.error("Błąd zapytania zdarzeń GA4:", e);
  }
}

// ---------------------------------------------------------------------------
// 4. Metryki pochodne i delty
// ---------------------------------------------------------------------------

const mainROAS = calcROAS(mainAds.conversionsValue, mainAds.cost);
const cmpROAS  = calcROAS(cmpAds.conversionsValue, cmpAds.cost);
const mainCPC  = calcCPC(mainAds.cost, mainAds.clicks);
const mainCTR  = calcCTR(mainAds.clicks, mainAds.impressions);

// Procentowe delty
const dRevenue     = percentChange(mainSales.revenue, cmpSales.revenue);
const dOrders      = percentChange(mainSales.orders, cmpSales.orders);
const dAOV         = percentChange(mainSales.aov, cmpSales.aov);
const dRefunds     = percentChange(mainSales.refunds, cmpSales.refunds);
const dCost        = percentChange(mainAds.cost, cmpAds.cost);
const dConvValue   = percentChange(mainAds.conversionsValue, cmpAds.conversionsValue);
const dConv        = percentChange(mainAds.conversions, cmpAds.conversions);
const dROAS        = cmpROAS !== null && mainROAS !== null
  ? percentChange(mainROAS, cmpROAS) : null;
const dSessions    = percentChange(mainGA4.sessions, cmpGA4.sessions);
const dEngaged     = percentChange(mainGA4.engagedSessions, cmpGA4.engagedSessions);
const dKeyEvents   = percentChange(mainGA4.keyEvents, cmpGA4.keyEvents);
const dImprShare   = mainAds.impressionShare !== null && cmpAds.impressionShare !== null
  ? percentChange(mainAds.impressionShare, cmpAds.impressionShare) : null;

// ---------------------------------------------------------------------------
// 5. Dane wykresów (konwersja grosze → PLN dla wykresów)
// ---------------------------------------------------------------------------

const mainSalesPLN: DailyPoint[] = mainSalesDaily.map((d) => ({ date: d.date, value: groszeToPLN(d.value) }));
const cmpSalesPLN:  DailyPoint[] = cmpSalesDaily.map((d)  => ({ date: d.date, value: groszeToPLN(d.value) }));
const mainAdsPLN: DailyAdsPoint[] = mainAdsDaily.map((d)  => ({ date: d.date, cost: groszeToPLN(d.cost), conversionsValue: groszeToPLN(d.conversionsValue) }));
const cmpAdsPLN:  DailyAdsPoint[] = cmpAdsDaily.map((d)   => ({ date: d.date, cost: groszeToPLN(d.cost), conversionsValue: groszeToPLN(d.conversionsValue) }));

// ---------------------------------------------------------------------------
// 6. Podsumowanie AI (graceful degradation)
// ---------------------------------------------------------------------------

// Klucz czytany z runtime env Cloudflare (jak w endpointach ingestu — nie import.meta.env)
const apiKey = Astro.locals.runtime.env.GEMINI_API_KEY;

// Trzy rozłączne stany: brak klucza / brak danych / błąd API / ok
type AiStatus = "ok" | "no-key" | "no-data" | "error";
let aiSummary: string | null = null;
let aiStatus: AiStatus = "ok";

const hasData = mainSales.orders > 0 || mainSales.revenue > 0 || mainGA4.sessions > 0;

if (!apiKey) {
  aiStatus = "no-key";
} else if (!hasData) {
  aiStatus = "no-data";
} else if (selectedShopId && selectedShop) {
  const summaryInput: SummaryInput = {
    shopId:       selectedShopId,
    shopName:     selectedShop.name,
    mainRange,
    compareRange,
    dataVersion:  selectedShop.data_version,
    metrics: {
      revenue:                 mainSales.revenue,
      orders:                  mainSales.orders,
      refundAmount:            mainSales.refunds,
      adsCost:                 mainAds.cost,
      adsConversionsValue:     mainAds.conversionsValue,
      sessions:                mainGA4.sessions,
      prevRevenue:             cmpSales.revenue,
      prevOrders:              cmpSales.orders,
      prevRefundAmount:        cmpSales.refunds,
      prevAdsCost:             cmpAds.cost,
      prevAdsConversionsValue: cmpAds.conversionsValue,
      prevSessions:            cmpGA4.sessions,
    },
  };

  // Jeden retry przy błędzie API (timeout, limit, sieć)
  const attempt = () => getOrGenerateSummary(db, summaryInput, apiKey);
  try {
    aiSummary = await attempt();
  } catch (err) {
    console.error("[AI] Gemini błąd (próba 1):", err);
    try {
      aiSummary = await attempt();
    } catch (err2) {
      console.error("[AI] Gemini błąd (próba 2):", err2);
      aiStatus = "error";
    }
  }
}

// ---------------------------------------------------------------------------
// Pomocnicy wyświetlania
// ---------------------------------------------------------------------------

function pct(val: number | null) {
  return val !== null ? `${(val * 100).toFixed(1)}%` : "—";
}

function deltaSpan(key: string, change: number | null) {
  const cls   = deltaClass(key, change);
  const arrow = deltaArrow(change);
  const val   = fmtDelta(change);
  return change !== null
    ? `<span class="delta ${cls}">${arrow} ${val}</span>`
    : `<span class="delta delta--neutral">—</span>`;
}

const topMax = topProducts[0]?.value ?? 1;

// ---------------------------------------------------------------------------
// Grupowanie zdarzeń GA4
// ---------------------------------------------------------------------------

interface EventSummary {
  eventName: string;
  total: number;
  byChannel: { channel: string; count: number }[];
}

const EVENT_GROUPS: Record<string, string[]> = {
  "eCommerce": ["view_item", "add_to_cart", "begin_checkout", "purchase"],
  "Kontakt":   ["click_tel", "click_mail", "form_submit"],
  "Ruch":      ["page_view"],
};

const eventSummaryMap = new Map<string, EventSummary>();
for (const row of ga4Events) {
  if (!eventSummaryMap.has(row.eventName)) {
    eventSummaryMap.set(row.eventName, { eventName: row.eventName, total: 0, byChannel: [] });
  }
  const ev = eventSummaryMap.get(row.eventName)!;
  ev.total += row.eventCount;
  ev.byChannel.push({ channel: row.channelGroup, count: row.eventCount });
}

const eventGroupsWithData = Object.entries(EVENT_GROUPS)
  .map(([groupName, events]) => ({
    groupName,
    events: events.filter((name) => eventSummaryMap.has(name)).map((name) => eventSummaryMap.get(name)!),
  }))
  .filter((g) => g.events.length > 0);
---

<Layout title={`${selectedShop?.name ?? "Dashboard"} — Store Analytics`}>

  <!-- ──────────────────── Pasek sterowania ──────────────────── -->
  <div class="sticky-bar">
    <span class="sticky-bar__brand">Store Analytics</span>
    {shops.length > 0 && (
      <ShopSelector client:load shops={shops} current={selectedShopId} />
    )}
    <PeriodPicker
      client:load
      type={params.type}
      anchor={params.anchor}
      compare={params.compare}
      customFrom={params.customMain?.start ?? ""}
      customTo={params.customMain?.end ?? ""}
      compareFrom={params.customCompare?.start ?? ""}
      compareTo={params.customCompare?.end ?? ""}
    />
    <form method="POST" action="/api/auth/logout" style="margin-left:auto;flex-shrink:0">
      <button type="submit" class="logout-btn">Wyloguj</button>
    </form>
  </div>

  <!-- Pasek kontekstu -->
  <div class="context-bar">
    {periodError
      ? <span class="badge-error">{periodError}</span>
      : <>
          {isInProgress && <span class="badge-ptd">W toku</span>}
          <span>{mainLabel}</span>
          <span style="color:var(--border-2)">vs</span>
          <span>{compareLabel}</span>
        </>
    }
  </div>

  <!-- ──────────────────── Zawartość ──────────────────── -->
  <div class="page-wrap">

    {shops.length === 0 ? (
      <div class="no-shops">
        <h2>Brak sklepów</h2>
        <p>Dodaj wiersz do tabeli <code>shops</code> i przeładuj stronę.</p>
      </div>
    ) : (
      <>

        <!-- ── Pasek KPI ── -->
        <div class="kpi-bar">
          <KPICard
            label="Przychód netto"
            current={formatPLNShort(mainSales.revenue)}
            compare={formatPLNShort(cmpSales.revenue)}
            change={dRevenue}
            metricKey="revenue"
          />
          <KPICard
            label="Zamówienia"
            current={String(mainSales.orders)}
            compare={String(cmpSales.orders)}
            change={dOrders}
            metricKey="orders"
          />
          <KPICard
            label="Wydatki reklamowe"
            current={formatPLNShort(mainAds.cost)}
            compare={formatPLNShort(cmpAds.cost)}
            change={dCost}
            metricKey="cost"
          />
          <KPICard
            label="ROAS"
            current={formatROAS(mainROAS)}
            compare={formatROAS(cmpROAS)}
            change={dROAS}
            metricKey="roas"
          />
        </div>

        <!-- ── Podsumowanie AI ── -->
        <AISummary summary={aiSummary} status={aiStatus} />

        <!-- ── Siatka kart ── -->
        <div class="cards-grid">

          <!-- KARTA: Sprzedaż -->
          <div class="card">
            <h2>Sprzedaż</h2>
            <div class="metrics-row">
              <div class="metric">
                <span class="metric__label">Przychód netto</span>
                <span class="metric__value">{formatPLN(mainSales.revenue)}</span>
                <div class="metric__compare">
                  <span>{formatPLN(cmpSales.revenue)}</span>
                  <Fragment set:html={deltaSpan("revenue", dRevenue)} />
                </div>
              </div>
              <div class="metric">
                <span class="metric__label">Zamówienia</span>
                <span class="metric__value">{mainSales.orders}</span>
                <div class="metric__compare">
                  <span>{cmpSales.orders}</span>
                  <Fragment set:html={deltaSpan("orders", dOrders)} />
                </div>
              </div>
              <div class="metric">
                <span class="metric__label">Śr. wartość zamów.</span>
                <span class="metric__value">{formatPLN(mainSales.aov)}</span>
                <div class="metric__compare">
                  <span>{formatPLN(cmpSales.aov)}</span>
                  <Fragment set:html={deltaSpan("aov", dAOV)} />
                </div>
              </div>
              <div class="metric">
                <span class="metric__label">Zwroty</span>
                <span class="metric__value">{formatPLNShort(mainSales.refunds)}</span>
                <div class="metric__compare">
                  <span>{formatPLNShort(cmpSales.refunds)}</span>
                  <Fragment set:html={deltaSpan("refunds", dRefunds)} />
                </div>
              </div>
            </div>
            <SalesChart
              client:load
              mainData={mainSalesPLN}
              compareData={cmpSalesPLN}
              mainRange={mainRange}
              compareRange={compareRange}
            />
          </div>

          <!-- KARTA: Reklama -->
          <div class="card">
            <h2>Google Ads</h2>
            <div class="metrics-row">
              <div class="metric">
                <span class="metric__label">Koszt</span>
                <span class="metric__value">{formatPLN(mainAds.cost)}</span>
                <div class="metric__compare">
                  <span>{formatPLN(cmpAds.cost)}</span>
                  <Fragment set:html={deltaSpan("cost", dCost)} />
                </div>
              </div>
              <div class="metric">
                <span class="metric__label">Wart. konwersji</span>
                <span class="metric__value">{formatPLNShort(mainAds.conversionsValue)}</span>
                <div class="metric__compare">
                  <span>{formatPLNShort(cmpAds.conversionsValue)}</span>
                  <Fragment set:html={deltaSpan("conversions", dConvValue)} />
                </div>
              </div>
              <div class="metric">
                <span class="metric__label">ROAS</span>
                <span class="metric__value">{formatROAS(mainROAS)}</span>
                <div class="metric__compare">
                  <span>{formatROAS(cmpROAS)}</span>
                  <Fragment set:html={deltaSpan("roas", dROAS)} />
                </div>
              </div>
              <div class="metric">
                <span class="metric__label">CPC</span>
                <span class="metric__value">{mainCPC !== null ? formatPLN(Math.round(mainCPC)) : "—"}</span>
              </div>
              <div class="metric">
                <span class="metric__label">CTR</span>
                <span class="metric__value">{mainCTR !== null ? `${mainCTR.toFixed(2).replace(".", ",")}%` : "—"}</span>
              </div>
              <div class="metric">
                <span class="metric__label">Konwersje</span>
                <span class="metric__value">{mainAds.conversions.toFixed(0)}</span>
                <div class="metric__compare">
                  <span>{cmpAds.conversions.toFixed(0)}</span>
                  <Fragment set:html={deltaSpan("conversions", dConv)} />
                </div>
              </div>
            </div>

            {/* Udział w wyświetleniach */}
            {mainAds.impressionShare !== null && (
              <div class="share-bars">
                <div class="share-bar-row">
                  <span class="share-bar-label">Udział (wygrany)</span>
                  <div class="share-bar-track">
                    <div class="share-bar-fill share-bar-fill--won"
                         style={`width:${(mainAds.impressionShare * 100).toFixed(0)}%`}></div>
                  </div>
                  <span class="share-bar-pct">
                    {pct(mainAds.impressionShare)}
                    <Fragment set:html={" "} />
                    <Fragment set:html={deltaSpan("impression_share", dImprShare)} />
                  </span>
                </div>
                {mainAds.budgetLostShare !== null && (
                  <div class="share-bar-row">
                    <span class="share-bar-label">Utrata (budżet)</span>
                    <div class="share-bar-track">
                      <div class="share-bar-fill share-bar-fill--budget"
                           style={`width:${(mainAds.budgetLostShare * 100).toFixed(0)}%`}></div>
                    </div>
                    <span class="share-bar-pct">{pct(mainAds.budgetLostShare)}</span>
                  </div>
                )}
                {mainAds.rankLostShare !== null && (
                  <div class="share-bar-row">
                    <span class="share-bar-label">Utrata (ranking)</span>
                    <div class="share-bar-track">
                      <div class="share-bar-fill share-bar-fill--rank"
                           style={`width:${(mainAds.rankLostShare * 100).toFixed(0)}%`}></div>
                    </div>
                    <span class="share-bar-pct">{pct(mainAds.rankLostShare)}</span>
                  </div>
                )}
              </div>
            )}

            <AdsChart
              client:load
              mainData={mainAdsPLN}
              compareData={cmpAdsPLN}
              mainRange={mainRange}
              compareRange={compareRange}
            />
            {adsConversions.length > 0 && (
              <div class="subsection">
                <p class="subsection-label">Konwersje</p>
                <table class="channel-table">
                  <thead>
                    <tr>
                      <th>Akcja</th>
                      <th class="num">Konwersje</th>
                      <th class="num">Wartość</th>
                    </tr>
                  </thead>
                  <tbody>
                    {adsConversions.map((c) => (
                      <tr>
                        <td>{c.action}</td>
                        <td class="num">{c.conversions.toFixed(0)}</td>
                        <td class="num">{formatPLNShort(c.conversionsValue)}</td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            )}
          </div>

          <!-- KARTA: Ruch GA4 -->
          <div class="card">
            <h2>Ruch (GA4)</h2>
            <div class="metrics-row">
              <div class="metric">
                <span class="metric__label">Sesje</span>
                <span class="metric__value">{mainGA4.sessions.toLocaleString("pl-PL")}</span>
                <div class="metric__compare">
                  <span>{cmpGA4.sessions.toLocaleString("pl-PL")}</span>
                  <Fragment set:html={deltaSpan("sessions", dSessions)} />
                </div>
              </div>
              <div class="metric">
                <span class="metric__label">Zaangażow.</span>
                <span class="metric__value">{mainGA4.engagedSessions.toLocaleString("pl-PL")}</span>
                <div class="metric__compare">
                  <span>{cmpGA4.engagedSessions.toLocaleString("pl-PL")}</span>
                  <Fragment set:html={deltaSpan("engaged_sessions", dEngaged)} />
                </div>
              </div>
              <div class="metric">
                <span class="metric__label">Wsk. zaangażow.</span>
                <span class="metric__value">{mainGA4.engagementRate.toFixed(1).replace(".", ",")}%</span>
              </div>
              <div class="metric">
                <span class="metric__label">Zdarzenia kluczowe</span>
                <span class="metric__value">{mainGA4.keyEvents.toLocaleString("pl-PL")}</span>
                <div class="metric__compare">
                  <span>{cmpGA4.keyEvents.toLocaleString("pl-PL")}</span>
                  <Fragment set:html={deltaSpan("key_events", dKeyEvents)} />
                </div>
              </div>
            </div>
            <Ga4Chart
              client:load
              mainData={mainGA4Daily}
              compareData={cmpGA4Daily}
              mainRange={mainRange}
              compareRange={compareRange}
            />
            {mainGA4.byChannel.length > 0 && (
              <table class="channel-table">
                <thead>
                  <tr>
                    <th>Kanał</th>
                    <th class="num">Sesje</th>
                    <th class="num">Zaangażow.</th>
                    <th class="num">Zdarzenia</th>
                  </tr>
                </thead>
                <tbody>
                  {mainGA4.byChannel.map((ch) => (
                    <tr>
                      <td>{ch.channel}</td>
                      <td class="num">{ch.sessions.toLocaleString("pl-PL")}</td>
                      <td class="num">{ch.engagedSessions.toLocaleString("pl-PL")}</td>
                      <td class="num">{ch.keyEvents.toLocaleString("pl-PL")}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            )}
            {eventGroupsWithData.length > 0 && (
              <div class="subsection">
                <p class="subsection-label">Zdarzenia</p>
                {eventGroupsWithData.map(({ groupName, events }) => (
                  <div class="event-group">
                    <p class="event-group__label">{groupName}</p>
                    {events.map((ev) => (
                      <div class="event-row">
                        <span class="event-row__name">{ev.eventName}</span>
                        <span class="event-row__total">{ev.total.toLocaleString("pl-PL")}</span>
                        <span class="event-channels">
                          {ev.byChannel.map((ch) => (
                            <span class="event-channel">{ch.channel}: {ch.count.toLocaleString("pl-PL")}</span>
                          ))}
                        </span>
                      </div>
                    ))}
                  </div>
                ))}
              </div>
            )}
          </div>

          <!-- KARTA: Top produkty -->
          <div class="card">
            <h2>Top produkty</h2>
            {topProducts.length === 0 ? (
              <p class="no-data">Brak danych o produktach w tym okresie.</p>
            ) : (
              <div>
                {topProducts.map((p, i) => (
                  <div class="product-row">
                    <span class="product-rank">{i + 1}</span>
                    <div style="min-width:0">
                      <div class="product-name" title={p.productName}>{p.productName}</div>
                      <div class="product-bar-wrap">
                        <div class="product-bar"
                             style={`width:${Math.round((p.value / topMax) * 100)}%`}></div>
                      </div>
                    </div>
                    <span class="product-value">{formatPLNShort(p.value)}</span>
                  </div>
                ))}
              </div>
            )}
          </div>

        </div>
      </>
    )}
  </div>
</Layout>
